{
  "multipart": [
    {
      "apply": {
        "model": "anvilcraft:block/pipe_node"
      }
    },
    {
      "apply": {
        "model": "anvilcraft:block/pipe_end"
      },
      "when": {
        "north": "end"
      }
    },
    {
      "apply": {
        "model": "anvilcraft:block/pipe_no_end"
      },
      "when": {
        "north": "pipe"
      }
    },
    {
      "apply": {
        "model": "anvilcraft:block/pipe_end",
        "y": 180
      },
      "when": {
        "south": "end"
      }
    },
    {
      "apply": {
        "model": "anvilcraft:block/pipe_no_end",
        "y": 180
      },
      "when": {
        "south": "pipe"
      }
    },
    {
      "apply": {
        "model": "anvilcraft:block/pipe_end",
        "y": 90
      },
      "when": {
        "east": "end"
      }
    },
    {
      "apply": {
        "model": "anvilcraft:block/pipe_no_end",
        "y": 90
      },
      "when": {
        "east": "pipe"
      }
    },
    {
      "apply": {
        "model": "anvilcraft:block/pipe_end",
        "y": 270
      },
      "when": {
        "west": "end"
      }
    },
    {
      "apply": {
        "model": "anvilcraft:block/pipe_no_end",
        "y": 270
      },
      "when": {
        "west": "pipe"
      }
    },
    {
      "apply": {
        "model": "anvilcraft:block/pipe_end",
        "x": 90
      },
      "when": {
        "down": "end"
      }
    },
    {
      "apply": {
        "model": "anvilcraft:block/pipe_no_end",
        "x": 90
      },
      "when": {
        "down": "pipe"
      }
    },
    {
      "apply": {
        "model": "anvilcraft:block/pipe_end",
        "x": 270
      },
      "when": {
        "up": "end"
      }
    },
    {
      "apply": {
        "model": "anvilcraft:block/pipe_no_end",
        "x": 270
      },
      "when": {
        "up": "pipe"
      }
    }
  ]
}