    {
      "type": "patchouli:multiblock",
      "anchor": "acceleration_ring",
      "name": "合成加速环",
      "multiblock":{
        "mapping": {
          "A": "minecraft:copper_block",
          "B": "anvilcraft:heavy_iron_block",
          "C": "anvilcraft:magnetoelectric_core",
          "D": "anvilcraft:tungsten_block"
        },
        "pattern": [
          ["ABA","B B","ABA"],
          ["CDC","D D","CDC"],
          ["ABA","B0B","ABA"]
        ]
      },
      "text": "通过$(thing)多方块合成$()获得$(item)加速环$()"
    },
    {
      "type": "patchouli:spotlight",
      "item": "anvilcraft:acceleration_ring",
      "text": "启用耗电量256kW，收到红石信号停用。$(br)当$(item)加速环$()正前方距离小于14个方块$()内有$(item)偏转环$()或相同方向的$(item)加速环$()(均需启用)，其可以加速$(thing)大部分铁砧$()(不包括巨型铁砧、幻灵铁砧)、$(thing)弹射物$()、$(thing)玩家$()(装备至少两件装备且头戴铁砧锤)，使其沿着加速轨道加速到$(thing)最大速度$()。"
    },
    {
