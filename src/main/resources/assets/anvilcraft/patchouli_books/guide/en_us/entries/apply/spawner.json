  "pages": [
    "$(l:smithing/corrupted_beacon#time_warp)时移$()操作可以将$(item)树脂(块)$()转化为$(item)琥珀(块)$()。$(br2)如果$(item)树脂块$()中含有的不是被动生物，则有$(thing)5%$()的概率产生$(item)怨恨琥珀块$()。$(br2)利用它和$(l:smithing/tier_1_materials#cursed_gold_block)诅咒金块$()可以生产对应敌对生物的$(item)刷怪笼$()。",
    {
      "type": "anvilcraft:time_warp",
      "recipe": "anvilcraft:time_warp/amber",
      "text": "琥珀块获取方式与琥珀同理 $(br2)部分高级别的$(l:smithing/jewelcrafting_table#jeweler)珠宝商$()会收购琥珀块"
    },
    {
      "type": "patchouli:multiblock",
      "name": "多方块结构转化刷怪笼",
      "multiblock": {
        "mapping": {
          "A": "anvilcraft:cursed_gold_block",
          "B": "minecraft:chain[waterlogged=false,axis=x]",
          "C": "minecraft:chain[waterlogged=false,axis=z]",
          "0": "minecraft:soul_fire",
          "E": "minecraft:chain[waterlogged=false,axis=y]",
          "F": "anvilcraft:resentful_amber_block[facing=west]"
        },
        "pattern": [
          ["ACA","B B","ACA"],
          ["E E"," F ","E E"],
          ["ACA","B0B","ACA"]
        ]
      },
      "text": "$(#aa0000)注意$()：生成刷怪笼仅接受$(l:struct/multiblock)多方块$(n)转化$()而非$(l:struct/multiblock#craft)多方块合成$()!"
    },
